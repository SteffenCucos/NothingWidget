<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widgetRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_nothing_background"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingLeft="12dp"
    android:paddingTop="11dp"
    android:paddingRight="12dp"
    android:paddingBottom="10dp">

    <TextView
        android:id="@+id/eventStatus"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:includeFontPadding="false"
        android:text="NEXT"
        android:textSize="1sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/statusAccentDot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:text="●"
            android:textColor="@color/widget_nothing_accent_red"
            android:textSize="7sp" />

        <TextView
            android:id="@+id/eventLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="5dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:fontFamily="monospace"
            android:includeFontPadding="false"
            android:lineSpacingExtra="0dp"
            android:lineSpacingMultiplier="0.76"
            android:maxLines="5"
            android:text="SUNSET"
            android:textColor="@color/widget_nothing_text_primary"
            android:textSize="5sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/eventTime"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:fontFamily="monospace"
        android:includeFontPadding="false"
        android:lineSpacingExtra="0dp"
        android:lineSpacingMultiplier="0.70"
        android:maxLines="5"
        android:text="7:42 PM"
        android:textColor="@color/widget_nothing_text_primary"
        android:textSize="10sp" />

    <ImageView
        android:id="@+id/eventIcon"
        android:layout_width="86dp"
        android:layout_height="54dp"
        android:layout_marginTop="2dp"
        android:contentDescription="@null"
        android:scaleType="fitCenter" />

    <TextView
        android:id="@+id/progressText"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:includeFontPadding="false"
        android:text="50%"
        android:textSize="1sp" />

    <TextView
        android:id="@+id/iconAccentDot"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:includeFontPadding="false"
        android:text="●"
        android:textSize="1sp" />

    <TextView
        android:id="@+id/eventRemaining"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:ellipsize="end"
        android:fontFamily="monospace"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:text="IN 2H 18M"
        android:textColor="@color/widget_nothing_text_secondary"
        android:textSize="8sp" />

    <ProgressBar
        android:id="@+id/eventProgress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:max="100"
        android:progress="50"
        android:progressDrawable="@drawable/widget_nothing_progress" />
</LinearLayout>

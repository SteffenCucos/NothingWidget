<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widgetRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingLeft="7dp"
    android:paddingTop="7dp"
    android:paddingRight="7dp"
    android:paddingBottom="6dp">

    <TextView
        android:id="@+id/eventStatus"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="NEXT" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/statusAccentDot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:text="&#8226;"
            android:textColor="@color/widget_nothing_accent_red"
            android:textSize="6sp" />

        <TextView
            android:id="@+id/eventLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="4dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:fontFamily="monospace"
            android:includeFontPadding="false"
            android:letterSpacing="0.08"
            android:maxLines="1"
            android:text="SUNSET"
            android:textColor="@color/widget_text_secondary"
            android:textSize="9sp" />
    </LinearLayout>

    <ImageView
        android:id="@+id/eventTime"
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:layout_marginTop="2dp"
        android:contentDescription="@null"
        android:scaleType="fitCenter" />

    <ImageView
        android:id="@+id/eventIcon"
        android:layout_width="58dp"
        android:layout_height="38dp"
        android:layout_marginTop="1dp"
        android:contentDescription="@null"
        android:scaleType="fitCenter" />

    <TextView
        android:id="@+id/progressText"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="50%" />

    <TextView
        android:id="@+id/iconAccentDot"
        android:layout_width="0dp"
        android:layout_height="0dp" />

    <TextView
        android:id="@+id/eventRemaining"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="1dp"
        android:ellipsize="end"
        android:fontFamily="monospace"
        android:gravity="center"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:text="IN 2H 18M"
        android:textColor="@color/widget_text_secondary"
        android:textSize="7sp" />
</LinearLayout>
